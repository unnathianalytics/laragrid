{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "unnathianalytics/laragrid",
    "description": "Excel-style, keyboard-first datagrid for Laravel + Livewire — display, server-side readonly, and editable grids, fully configured from the component class with zero blade wiring and zero consumer build tooling.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "livewire",
        "alpine",
        "datagrid",
        "grid",
        "table",
        "spreadsheet",
        "excel"
    ],
    "authors": [
        {
            "name": "Unnathi",
            "email": "unnathianalytics@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^4.1"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^8.21|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.34|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "LaraGrid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraGrid\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraGrid\\LaraGridServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --parallel",
        "types": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [{
        "name": "laragrid",
        "type": "vcs",
        "url": "https://github.com/unnathianalytics/laragrid"
    }]
}
